@article{PENG2025118090,
title = {A high-precision dynamic RGB-D SLAM algorithm for environments with potential semantic segmentation network failures},
journal = {Measurement},
volume = {256},
pages = {118090},
year = {2025},
issn = {0263-2241},
doi = {https://doi.org/10.1016/j.measurement.2025.118090},
url = {https://www.sciencedirect.com/science/article/pii/S0263224125014496},
author = {Yifan Peng and Rui Xv and Wenwen Lu and Xiaorui Wu and Yvmeng Xv and Yifei Wu and Qingwei Chen},
keywords = {Dynamic visual SLAM, Pose measurement, Data association, Epipolar geometry, Environment perception},
abstract = {Most deep learning-based dynamic visual SLAM systems struggle to accurately recognize unknown dynamic objects in scenes, particularly those that are highly ambiguous or irregular, resulting in degraded pose measurement accuracy. Besides, these systems primarily focus on pose estimation performance and overlook environmental perception. This paper proposes a high-precision RGB-D SLAM system specifically designed for dynamic scenarios where semantic segmentation networks may fail. The system integrates an Asymmetric Non-local Neural (ANN) Network for semantic segmentation with a static dense point cloud mapping thread. Through an innovative combination of depth image clustering, based on a weight-variable K-Means algorithm, and multi-view geometry constraints, the system can identify unknown dynamic objects when semantic information is unreliable. Further incorporating semantic information extracted by the ANN network, the system effectively filters out dynamic outliers in the SLAM front-end and removes dynamic pixels in keyframes. The mapping thread selectively projects static pixels in keyframes to construct the point cloud map utilizing high-precision localization results. Additionally, loop closure constraints are incorporated to ensure global consistency of the map. Experimental comparisons with mainstream dynamic visual SLAM systems demonstrate significant improvements in pose measurement accuracy, particularly in challenging scenarios where semantic segmentation networks may fail, while maintaining the ability to construct high-quality static point cloud maps. The experimental results validate the system’s effectiveness in both high-precision localization and environmental perception tasks.}
}


